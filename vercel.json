{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "src/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",                                                 "dest": "/server.ts"      },
    { "src": "/assets/(.*)",                                              "dest": "/dist/assets/$1" },
    { "src": "/(.*\\.(js|css|ico|png|svg|woff|woff2|ttf|map|webp))",     "dest": "/dist/$1"        },
    { "src": "/(.*)",                                                     "dest": "/server.ts"      }
  ]
}
